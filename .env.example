# HypoArena talks to LLMs through one or more OpenAI-compatible platforms.
# Configure at least one below; each needs an API key and a base URL.
# The FallbackModel tries platforms in order and promotes whichever succeeds,
# so the same model can be registered on several platforms for resiliency.
#
# Map the placeholder names (platform_a .. platform_d) in basics/models.py to
# whatever providers you use.

# PLATFORM_A
PLATFORM_A_API_KEY=
PLATFORM_A_BASE_URL=

# PLATFORM_B
PLATFORM_B_API_KEY=
PLATFORM_B_BASE_URL=

# PLATFORM_C
PLATFORM_C_API_KEY=
PLATFORM_C_BASE_URL=

# PLATFORM_D
PLATFORM_D_API_KEY=
PLATFORM_D_BASE_URL=
